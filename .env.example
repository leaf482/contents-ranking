# Contents Ranking - Environment Variables
# Copy to .env and adjust for your setup.
# For Docker Compose, these are set in docker-compose.yml (no .env needed for default run).

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=video-heartbeats

# ── Go API ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379

# ── Worker (optional) ──────────────────────────────────────────────────────────
BATCH_SIZE=50
BATCH_FLUSH_INTERVAL=100ms

# ── AI Worker (Go Kafka consumer + Dashboard chat proxy) ──────────────────────
CLOUDFLARE_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# Optional: call Cloudflare Worker directly from the browser (skips /api/cf proxy)
# NEXT_PUBLIC_CLOUDFLARE_AI_URL=https://your-worker.your-subdomain.workers.dev

# ── Simulation (optional, for host-mode) ───────────────────────────────────────
# RANKING_API_URL=http://localhost:8080/v1/heartbeat
# PROMETHEUS_URL=http://localhost:9090

# ── Dashboard (optional, for host-mode) ────────────────────────────────────────
# GO_API_URL=http://localhost:8080
# SIMULATION_URL=http://localhost:3000
